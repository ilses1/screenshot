{
  "name": "electron-screenshot",
  "private": true,
  "description": "electron 截图工具",
  "author": {
    "name": "wusan"
  },
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.example.electron-screenshot",
    "productName": "Electron Screenshot",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "out/**",
      "src/renderer/**",
      "assets/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/favicon.ico"
    }
  },
  "dependencies": {
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "electron-builder": "^24.13.3"
  }
}